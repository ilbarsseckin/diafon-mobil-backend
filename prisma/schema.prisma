generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(uuid())
  name          String
  phone         String     @unique
  email         String?
  role          UserRole   @default(GUEST)
  photoUrl      String?    @map("photo_url")
  phoneVerified Boolean    @default(false) @map("phone_verified")
  fcmToken      String?    @map("fcm_token")
  voipToken     String?    @map("voip_token")
  isOnline      Boolean    @default(false) @map("is_online")
  blocked       Boolean    @default(false)
  createdAt     DateTime   @default(now()) @map("created_at")
  isPremium     Boolean    @default(false) @map("is_premium")
  deletionRequestedAt DateTime? @map("deletion_requested_at")
  callerCalls   Call[]     @relation("CallerUser")
  receiverCalls Call[]     @relation("ReceiverUser")
  residents     Resident[]
  vehicleLinks  VehicleUser[]
  @@map("users")
}

model Building {
  id                   String      @id @default(uuid())
  buildingName         String      @map("building_name")
  address              String?
  latitude             Float
  longitude            Float
  radiusMeter          Int         @default(30) @map("radius_meter")
  createdAt            DateTime    @default(now()) @map("created_at")
  qrToken              String?     @unique @map("qr_token")
  blockName            String?     @map("block_name")
  ownerUserId          String?     @map("owner_user_id")
  requireApproval      Boolean     @default(false) @map("require_approval")
  siteName             String?     @map("site_name")
  imageUrl             String?     @map("image_url")
  locationCheckEnabled Boolean     @default(false) @map("location_check_enabled")
  locationCheckRadius  Int         @default(150) @map("location_check_radius")
  doorAdapter          String?     @map("door_adapter")
  doorDeviceId         String?     @map("door_device_id")
  doorEnabled          Boolean     @default(false) @map("door_enabled")
  type                 String      @default("residential")
  businessCategory     String?     @map("business_category")
  securityMode         String      @default("qr") @map("security_mode")
  apartments           Apartment[]
  calls                Call[]
  @@map("buildings")
}

model Apartment {
  id            String     @id @default(uuid())
  buildingId    String     @map("building_id")
  flatNo        String     @map("flat_no")
  floor         String?
  createdAt     DateTime   @default(now()) @map("created_at")
  listingStatus String     @default("none") @map("listing_status")
  qrToken       String?    @unique @map("qr_token")
  qrLabel       String?    @map("qr_label")
  building      Building   @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  notes         Note[]
  residents     Resident[]
  @@map("apartments")
}

model Resident {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  apartmentId String    @map("apartment_id")
  visible     Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  approved    Boolean   @default(true)
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, apartmentId])
  @@map("residents")
}

model Call {
  id             String     @id @default(uuid())
  callerUserId   String?    @map("caller_user_id")
  receiverUserId String     @map("receiver_user_id")
  buildingId     String?    @map("building_id")
  startedAt      DateTime   @default(now()) @map("started_at")
  endedAt        DateTime?  @map("ended_at")
  duration       Int?
  status         CallStatus @default(RINGING)
  callerPhotoUrl String?    @map("caller_photo_url")
  guestName      String?    @map("guest_name")
  apartmentId    String?    @map("apartment_id")
  callerLat      Float?     @map("caller_lat")
  callerLng      Float?     @map("caller_lng")
  vehicleId      String?    @map("vehicle_id")
  building       Building?  @relation(fields: [buildingId], references: [id])
  callerUser     User?      @relation("CallerUser", fields: [callerUserId], references: [id], onDelete: Restrict)
  receiverUser   User       @relation("ReceiverUser", fields: [receiverUserId], references: [id])
  @@map("calls")
}

model Note {
  id          String    @id @default(uuid())
  apartmentId String    @map("apartment_id")
  fromUserId  String?   @map("from_user_id")
  fromRole    String    @map("from_role")
  fromName    String?   @map("from_name")
  text        String
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now()) @map("created_at")
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  @@map("notes")
}

model Door {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  buildingId String   @map("building_id")
  name       String
  adapter    String   @default("tuya")
  deviceId   String   @map("device_id")
  enabled    Boolean  @default(true)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([buildingId], map: "idx_doors_building")
  @@map("doors")
}

model DoorLog {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String   @map("user_id")
  buildingId String   @map("building_id")
  callId     String?  @map("call_id")
  doorId     String?  @map("door_id")
  success    Boolean  @default(false)
  error      String?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([buildingId], map: "idx_door_logs_building")
  @@map("door_logs")
}

model SecurityGuard {
  id          String   @id @default(uuid())
  ownerUserId String   @map("owner_user_id")
  phone       String
  guardName   String?  @map("guard_name")
  createdAt   DateTime @default(now()) @map("created_at")
  @@unique([ownerUserId, phone])
  @@map("security_guards")
}

model Subscription {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  ownerUserId     String    @map("owner_user_id")
  scopeType       String    @default("site") @map("scope_type")
  scopeName       String    @map("scope_name")
  status          String    @default("trial")
  plan            String?
  flatCount       Int       @default(0) @map("flat_count")
  monthlyPrice    Int       @default(0) @map("monthly_price")
  trialEndsAt     DateTime? @map("trial_ends_at")
  currentPeriodEnd DateTime? @map("current_period_end")
  vehicleId        String?   @map("vehicle_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  @@index([ownerUserId], map: "idx_subs_owner")
  @@index([vehicleId], map: "idx_subs_vehicle")
  @@map("subscriptions")
}

model Payment {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId          String    @map("user_id")
  subscriptionId  String    @map("subscription_id")
  amount          Float
  period          String
  status          String    @default("pending")
  conversationId  String?   @map("conversation_id")
  iyzicoPaymentId String?   @map("iyzico_payment_id")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  @@map("payments")
}

model Plan {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar
  minUnits     Int      @map("min_units")
  maxUnits     Int?     @map("max_units")
  monthlyPrice Int      @map("monthly_price")
  yearlyPrice  Int      @map("yearly_price")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  @@map("plans")
}

model SiteText {
  id        String   @id @default(uuid())
  key       String   @unique
  valueTr   String   @map("value_tr")
  valueEn   String   @map("value_en")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  @@map("site_texts")
}

model Invoice {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  ownerUserId    String    @map("owner_user_id")
  title          String?
  amount         Int?
  paymentStatus String    @default("pending") @map("payment_status")
  fileUrl        String?   @map("file_url")        // yuklenen PDF yolu
  uploadedAt     DateTime? @map("uploaded_at")     // PDF yuklendi mi
  sentAt         DateTime? @map("sent_at")         // mail gitti mi (null = gonderilmedi)
  buildingId     String?   @map("building_id")     // opsiyonel: hangi bina/isletme
  vehicleId      String?   @map("vehicle_id")      // opsiyonel: hangi arac QR
  note           String?
  createdAt      DateTime  @default(now()) @map("created_at")
  @@index([ownerUserId], map: "idx_invoices_owner")
  @@map("invoices")
}

enum CallStatus {
  RINGING
  ACCEPTED
  REJECTED
  MISSED
  ENDED
}

enum UserRole {
  GUEST
  RESIDENT
  ADMIN
}

model Vehicle {
  id             String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  ownerUserId    String?  @map("owner_user_id")
  label          String?
  plate          String?
  code           String   @unique
  secretCodeHash String   @map("secret_code_hash")
  status         String   @default("unsold")
  activeMessage  String?  @map("active_message")
  createdAt      DateTime @default(now()) @map("created_at")

  secondaryUsers VehicleUser[]

  @@index([ownerUserId], map: "idx_vehicles_owner")
  @@map("vehicles")
}

model VehicleUser {
  id        String   @id @default(uuid())
  vehicleId String   @map("vehicle_id")
  userId    String   @map("user_id")
  role      String   @default("secondary")
  createdAt DateTime @default(now()) @map("created_at")
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([vehicleId, userId])
  @@map("vehicle_users")
}

model VehicleOrder {
  id                String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  buyerName         String    @map("buyer_name")
  buyerPhone        String    @map("buyer_phone")
  buyerEmail        String?   @map("buyer_email")
  shipCity          String    @map("ship_city")
  shipDistrict      String?   @map("ship_district")
  shipAddress       String    @map("ship_address")
  amount            Int
  status            String    @default("pending")
  shipStatus        String    @default("preparing") @map("ship_status")
  trackingNo        String?   @map("tracking_no")
  conversationId    String?   @map("conversation_id")
  iyzicoPaymentId   String?   @map("iyzico_payment_id")
  vehicleCode       String?   @map("vehicle_code")
  vehicleSecretCode String?   @map("vehicle_secret_code")
  buyerUserId       String?   @map("buyer_user_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  paidAt            DateTime? @map("paid_at")
  shippedAt         DateTime? @map("shipped_at")
  @@index([status], map: "idx_vorders_status")
  @@map("vehicle_orders")
}

